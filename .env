# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=feature_store
POSTGRES_USER=fsuser
POSTGRES_PASSWORD=fspassword
POSTGRES_MIN_POOL=2
POSTGRES_MAX_POOL=20

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL_SECONDS=86400

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_FEATURE_UPDATES_TOPIC=feature-updates
KAFKA_SCHEMA_CHANGES_TOPIC=schema-changes
KAFKA_CONSUMER_GROUP=feature-store-consumer
KAFKA_AUTO_OFFSET_RESET=earliest

# API
API_HOST=0.0.0.0
API_PORT=8000

# Materialization
MATERIALIZATION_BATCH_SIZE=1000
ONLINE_FEATURE_TTL_SECONDS=86400
